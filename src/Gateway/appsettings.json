{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "upload-route": {
        "ClusterId": "upload-cluster",
        "Match": {
          "Path": "/api/uploads/{**catch-all}"
        }
      },
      "jobs-route": {
        "ClusterId": "job-cluster",
        "Match": {
          "Path": "/api/jobs/{**catch-all}"
        }
      },
      "photos-route": {
        "ClusterId": "gallery-cluster",
        "Match": {
          "Path": "/api/photos/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "upload-cluster": {
        "Destinations": {
          "upload-service": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "job-cluster": {
        "Destinations": {
          "job-service": {
            "Address": "http://localhost:5102"
          }
        }
      },
      "gallery-cluster": {
        "Destinations": {
          "gallery-service": {
            "Address": "http://localhost:5103"
          }
        }
      }
    }
  }
}
